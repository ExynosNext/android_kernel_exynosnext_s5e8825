# ExynosNext Kernel — EditorConfig
# Consistent code style across all contributors

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 8

[*.{c,h}]
indent_style = tab
indent_size = 8
max_line_length = 100

[*.{sh,bash}]
indent_style = tab
indent_size = 4

[*.{py}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 8

[*.md]
trim_trailing_whitespace = false

[*.dts]
indent_style = tab
indent_size = 8
