/*
 * Samsung Galaxy A26 5G (SM-A266B) Device Tree
 *
 * Board-level peripherals: PMIC, touch, display panel, fingerprint,
 * storage.  Addresses and GPIO assignments are PLACEHOLDERS.
 */

/dts-v1/;

#include "exynos1280.dtsi"
#include "exynos1280-pmic-s2mps34.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Samsung Galaxy A26 5G (SM-A266B)";
	compatible = "samsung,a26x", "samsung,exynos1280";

	chosen {
		bootargs = "androidboot.hardware=exynos1280";
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x0 0x80000000 0x0 0x180000000>; /* 6 GB */
	};

	/* ── Fixed regulators ─────────────────────────────────────────── */

	reg_vdd_emmc: regulator-vdd-emmc {
		compatible = "regulator-fixed";
		regulator-name = "vdd_emmc";
		regulator-min-microvolt = <2900000>;
		regulator-max-microvolt = <2900000>;
		regulator-always-on;
	};
};

/* ── UART ────────────────────────────────────────────────────────────── */

&serial1 {
	status = "okay";
};

/* ── I2C0: PMIC ─────────────────────────────────────────────────────── */

&i2c0 {
	status = "okay";

	s2mps34_pmic: pmic@66 {
		compatible = "samsung,s2mps34-pmic";
		reg = <0x66>;
		/* Full regulator set (39 LDO + 9 BUCK) is provided by the
		 * included exynos1280-pmic-s2mps34.dtsi. */
	};
};

/* ── I2C1: Touchscreen ──────────────────────────────────────────────── */

&i2c1 {
	status = "okay";

	touchscreen@38 {
		compatible = "focaltech,ft3658";
		reg = <0x38>;
		interrupt-parent = <&gph0>;
		interrupts = <5 IRQ_TYPE_EDGE_FALLING>;
		reset-gpios = <&gph0 6 GPIO_ACTIVE_LOW>;
	};
};

/* ── SPI1: Fingerprint ──────────────────────────────────────────────── */

&spi1 {
	status = "okay";

	fingerprint@0 {
		compatible = "egistec,etspis";
		reg = <0>;
		spi-max-frequency = <9600000>;
		interrupt-parent = <&gpi0>;
		interrupts = <6 IRQ_TYPE_EDGE_FALLING>;
		reset-gpios = <&gpi0 7 GPIO_ACTIVE_LOW>;
	};
};

/* ── Display ─────────────────────────────────────────────────────────── */

&decon {
	status = "okay";
};

&dsim0 {
	status = "okay";

	panel@0 {
		compatible = "samsung,s6e3fc3x01";
		reg = <0>;
		reset-gpios = <&gpi1 0 GPIO_ACTIVE_LOW>;
		enable-gpios = <&gpi1 1 GPIO_ACTIVE_HIGH>;
		vdd-supply = <&ldo6>;
	};
};

/* ── eMMC ────────────────────────────────────────────────────────────── */

&sdhci0 {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	non-removable;
	vmmc-supply = <&reg_vdd_emmc>;
};

/* ── SD card ─────────────────────────────────────────────────────────── */

&sdhci2 {
	status = "okay";
	bus-width = <4>;
	cap-sd-highspeed;
	disable-wp;
};

/* ── USB ─────────────────────────────────────────────────────────────── */

&usbdrd {
	status = "okay";
};

&usbdrd_dwc3 {
	dr_mode = "peripheral";
	maximum-speed = "high-speed";
};

/* ── UFS ─────────────────────────────────────────────────────────────── */

&ufshc {
	status = "okay";
};

/* ── GPU ─────────────────────────────────────────────────────────────── */

&gpu {
	status = "okay";
};

/* ── MFC ─────────────────────────────────────────────────────────────── */

&mfc {
	status = "okay";
};

/* ── Audio ───────────────────────────────────────────────────────────── */

&i2s0 {
	status = "okay";
};

/* ── Modem ───────────────────────────────────────────────────────────── */

&cpif {
	status = "okay";
};

/* ── NFC ─────────────────────────────────────────────────────────────── */

&nfc {
	status = "okay";
};
