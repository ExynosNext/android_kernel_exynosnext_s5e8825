/*
 * Samsung Galaxy A26 (SM-A266E) Device Tree
 * ExynosNext Kernel — Linux 6.18 LTS
 */

/dts-v1/;

#include "exynos1280.dtsi"

/ {
	model = "Samsung Galaxy A26 (SM-A266E)";
	compatible = "samsung,exynos1280-a26xs", "samsung,exynos1280";

	chosen {
		bootargs = "androidboot.hardware=exynos1280 androidboot.fstab_version=2";
	};

	/* TODO: Port from Samsung's a26xs DTS:
	 *   - Panel: AMOLED (Samsung)
	 *   - Touch: Goodix GT9895
	 *   - Camera: Triple camera setup
	 *   - Audio: RT5665 codec
	 *   - WiFi: SCSC
	 *   - Battery: S2MF301
	 *   - Fingerprint: Side-mounted
	 *   - NFC: YES
	 *   - USB: Type-C, 25W charging
	 */
};
