// SPDX-License-Identifier: GPL-2.0
/*
 * Samsung Galaxy A53 5G (SM-A536B) Device Tree
 *
 * Board-level peripherals: PMIC (S2MPS34), touchscreen, display panel,
 * fingerprint, UFS storage, USB. Base SoC nodes come from exynos1280.dtsi
 * (transcribed from Samsung firmware A536BXXSMGZE1).
 */

/dts-v1/;

#include "exynos1280.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Samsung Galaxy A53 5G (SM-A536B)";
	compatible = "samsung,a53x", "samsung,exynos1280";

	chosen {
		bootargs = "androidboot.hardware=exynos1280 clk_ignore_unused firmware_class.path=/vendor/firmware loop.max_part=7";
	};

	memory@80000000 {
		device_type = "memory";
		reg = <0x0 0x80000000 0x1 0x80000000>; /* 6 GB */
	};

	/* â”€â”€ Fixed regulators â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

	reg_vdd_emmc: regulator-vdd-emmc {
		compatible = "regulator-fixed";
		regulator-name = "vdd_emmc";
		regulator-min-microvolt = <2900000>;
		regulator-max-microvolt = <2900000>;
		regulator-always-on;
	};
};

/* â”€â”€ UART0: debug console â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&uart0 {
	status = "okay";
};

/* â”€â”€ HSI2C0: PMIC (S2MPS34) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&hsi2c0 {
	status = "okay";

	s2mps34_pmic: pmic@66 {
		compatible = "samsung,s2mps34-pmic";
		reg = <0x66>;
		#include "exynos1280-pmic-s2mps34.dtsi"
		/* Full regulator set (39 LDO + 9 BUCK) is provided by the
		 * included exynos1280-pmic-s2mps34.dtsi. */
	};
};

/* â”€â”€ HSI2C1: Touchscreen â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&hsi2c1 {
	status = "okay";

	touchscreen@14 {
		compatible = "goodix,gt9916r";
		reg = <0x14>;
		/* GPIO/pinctrl wiring to be confirmed against board schematic. */
	};
};

/* â”€â”€ SPI1: Fingerprint â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&spi1 {
	status = "okay";

	fingerprint@0 {
		compatible = "egistec,etspis";
		reg = <0>;
		spi-max-frequency = <9600000>;
	};
};

/* â”€â”€ Display â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&decon {
	status = "okay";
};

&dsim0 {
	status = "okay";

	panel@0 {
		compatible = "samsung,ams646ya01";
		reg = <0>;
		vdd-supply = <&ldo6>;
	};
};

/* â”€â”€ UFS (internal storage) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&ufs {
	status = "okay";
};

/* â”€â”€ eMMC (DWMMC2) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&dwmmc2 {
	status = "okay";
	bus-width = <8>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	non-removable;
	vmmc-supply = <&reg_vdd_emmc>;
};

/* â”€â”€ USB â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&usbdrd {
	status = "okay";
};

/* â”€â”€ GPU â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&gpu {
	status = "okay";
};

/* â”€â”€ Audio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&abox {
	status = "okay";
};

/* â”€â”€ WiFi/BT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&wifibt {
	status = "okay";
};

/* â”€â”€ RTC â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */

&rtc {
	status = "okay";
};
