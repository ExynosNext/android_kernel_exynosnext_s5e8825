# ExynosNext Vendor Modules — Master BUILD.bazel
# Builds all Samsung vendor modules for Exynos 1280

load("//common:kernel.bzl", "ddk_module")

# ── Clock Controller ────────────────────────────────────────────────────────

ddk_module(
    name = "clock",
    srcs = ["clock/clk-s5e8825.c"],
    out = "clk_s5e8825.ko",
    kernel_build = "//common:kernel_aarch64",
    deps = ["//common:all_headers_aarch64"],
    visibility = ["//visibility:public"],
)

