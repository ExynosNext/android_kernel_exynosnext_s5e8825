# ============================================================================
# ExynosNext OneUI Configuration Fragment
# Applied on top of vendor_exynosnext.config for Samsung OneUI ROM compatibility
#
# This fragment enables the vendor hooks and framework hooks that Samsung's
# OneUI user-space expects from the kernel. It does NOT enable root (KSU is
# controlled separately). Apply this fragment after vendor_exynosnext.config
# for the *-oneui variants.
#
# Every symbol here is a standard upstream/ACK GKI option; unknown symbols are
# dropped silently by merge_config.sh, so keep this list clean.
# ============================================================================

# ── Vendor / Android hooks (required by OneUI framework) ────────────────────
CONFIG_ANDROID_VENDOR_HOOKS=y
CONFIG_ANDROID_KABI_ASSERTIONS=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y

# ── Tracing hooks OneUI uses for ftrace/bpftrace ────────────────────────────
CONFIG_TRACEPOINTS=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_STACK_TRACER=y
CONFIG_SCHED_TRACER=y
CONFIG_HWLAT_TRACER=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_ENABLE_DEFAULT_TRACERS=y

# ── binder / ashmem / IPC (OneUI heavy IPC usage) ───────────────────────────
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ASHMEM=y

# ── SELinux (OneUI enforces; keep permissive-capable for dev) ────────────────
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_BOOTPARAM_VALUE=1
CONFIG_SECURITY_SELINUX_DISABLE=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_AVC_STATS=y
CONFIG_SECURITY_SELINUX_CHECKREQPROT_VALUE=0

# ── Samsung KNOX compatibility stubs ─────────────────────────────────────────
CONFIG_SECURITY_SELICK=y
# CONFIG_KnoxNad is Samsung-private; left unset (dropped silently if absent)

# ── Samsung vendor hooks (sched, thermal, cpufreq) ───────────────────────────
CONFIG_SAMSUNG_VH_SCHED=y
CONFIG_SAMSUNG_VH_THERMAL=y
CONFIG_SAMSUNG_VH_CPUFREQ=y
CONFIG_SAMSUNG_VH_IRQ=y
CONFIG_SAMSUNG_VH_AUD=y

# ── debugfs / proc (OneUI diagnostics expect these) ─────────────────────────
CONFIG_DEBUG_FS=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_SYSCTL=y

# ── devfreq / DVFS (OneUI power framework uses these) ────────────────────────
CONFIG_DEVFREQ_GOV_PERFORMANCE=y
CONFIG_DEVFREQ_GOV_POWERSAVE=y
CONFIG_DEVFREQ_GOV_USERSPACE=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_SIMPLE_INTERACTIVE=y

# ── Memory: OneUI uses dm-buf-io for media, KMS, camera ──────────────────────
CONFIG_DM_BUFIO=y
CONFIG_DM_CACHE=y
CONFIG_DM_CACHE_SMQ=y

# ── Networking OneUI relies on ──────────────────────────────────────────────
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_SCH_PRIO=y
CONFIG_NET_SCH_TBF=y
CONFIG_NET_CLS_FW=y
CONFIG_NET_CLS_U32=y

# ── IoT / HAL support ────────────────────────────────────────────────────────
CONFIG_SENSORS=y
CONFIG_IIO=y
CONFIG_IIO_BUFFER_CB=y
CONFIG_IIO_CONFIGFS=y

# ── LED / vibrator (OneUI haptics) ──────────────────────────────────────────
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_CLASS_FLASH=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_PWM=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y

# ── Samsung-specific sysfs (dropped silently if symbol absent) ────────────────
CONFIG_SEC_SYSFS=y
CONFIG_SEC_PARAM=y
CONFIG_SEC_REBOOT=y
CONFIG_SEC_DEBUG=y
CONFIG_SEC_QUEST=y

# ── MTP / PTP / ADB (USB functions OneUI needs) ─────────────────────────────
CONFIG_USB_F_ACM=y
CONFIG_USB_F_ECM=y
CONFIG_USB_F_MASS_STORAGE=y
CONFIG_USB_F_MTP=y
CONFIG_USB_F_PTP=y
CONFIG_USB_F_RNDIS=y
CONFIG_USB_F_ADB=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_UEVENT=y

# ── Filesystem features OneUI uses ──────────────────────────────────────────
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_FS_POSIX_ACL=y
CONFIG_FANOTIFY=y
CONFIG_FANOTIFY_ACCESS_PERMISSIONS=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y

# ── Build info / versioning ─────────────────────────────────────────────────
CONFIG_LOCALVERSION="-ExynosNext-OneUI"
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_DEFAULT_HOSTNAME="exynosnext"
