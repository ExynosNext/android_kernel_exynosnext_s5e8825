# ============================================================================
# ExynosNext Kernel Configuration Fragment
# Applied on top of gki_defconfig via Kleaf post_defconfig_fragments
# Target: Samsung Exynos 1280 (s5e8825) — Linux 6.18 LTS
# ============================================================================

# ── SoC: Exynos 1280 ───────────────────────────────────────────────────────
CONFIG_ARCH_EXYNOS=y
CONFIG_ARCH_EXYNOS_AUTO=n
CONFIG_SOC_S5E8825=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_IOMMU_SUPPORT=y

# ── Clock controller ────────────────────────────────────────────────────────
CONFIG_COMMON_CLK_S5E8825=m
CONFIG_COMMON_CLK=y
CONFIG_CLK_PPMU=y

# ── Display / DRM ───────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_SAMSUNG_DPU=m
CONFIG_DRM_SAMSUNG_DECON=y
CONFIG_DRM_SAMSUNG_DSI=m
CONFIG_DRM_SAMSUNG_PANEL=y
CONFIG_DRM_SAMSUNG_DPP=y
CONFIG_DRM_MCD_PANEL=y
CONFIG_DRM_MCD_HDR=y
CONFIG_USDM_MDNIE=y
CONFIG_USDM_MDNIE_AFC=y
CONFIG_USDM_MDNIE_TUNING=y
CONFIG_USDM_PANEL_COPR=y
CONFIG_PANEL_VRR_BRIDGE=y
CONFIG_PANEL_FREQ_HOP=y
CONFIG_PANEL_DISPLAY_MODE=y
CONFIG_PANEL_AID_DIMMING=y
CONFIG_PANEL_MDNIE_LIGHT_NOTIFICATION=y
CONFIG_SUPPORT_DYNAMIC_HLPM=y
CONFIG_MCD_PANEL_LPM=y
CONFIG_MCD_PANEL_BLIC=y

# ── Power domain ────────────────────────────────────────────────────────────
CONFIG_EXYNOS_PD=m
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_PM_RUNTIME=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_PM_WAKELOCKS=y
CONFIG_ENERGY_MODEL=y
CONFIG_CPU_IDLE=y

# ── Modem (CPIF) ───────────────────────────────────────────────────────────
CONFIG_SAMSUNG_CPIF=m
CONFIG_SAMSUNG_CPIF_SMP2P=y
CONFIG_SAMSUNG_MODEMCTL=m

# ── WiFi (SCSC) ─────────────────────────────────────────────────────────────
CONFIG_SCSC_WLAN=m
CONFIG_SCSC_WLAN_KEY_MGMT_OFFLOAD=y
CONFIG_SCSC_WLAN_SG=y
CONFIG_SCSC_WLAN_RX_NAPI=y
CONFIG_SCSC_WLAN_RX_NAPI_GRO=y
CONFIG_SCSC_WLAN_ANDROID=y
CONFIG_SCSC_WLAN_GSCAN_ENABLE=y
CONFIG_SCSC_WLAN_WIFI_SHARING=y
CONFIG_SCSC_WLAN_SINGLE_ANTENNA=y
CONFIG_SCSC_WLAN_ACS_ENABLE=y
CONFIG_SCSC_WLAN_MHS_STATIC_INTERFACE=y
CONFIG_SCSC_WLAN_NUM_ANTENNAS=y
CONFIG_SCSC_ENHANCED_PACKET_STATS=y
CONFIG_SCSC_WLAN_LOW_LATENCY_MODE=y
CONFIG_SCSC_WLAN_HE=y
CONFIG_SCSC_WLAN_BSS_COLOR=y
CONFIG_SCSC_WLAN_RTT=y
CONFIG_SCSC_WLAN_DUAL_STATION=y
CONFIG_SCSC_WLAN_MAX_LINK_SPEED=y
CONFIG_SCSC_WLAN_EXPONENTIAL_SCHED_SCAN=y
CONFIG_SCSC_WLAN_OCV_SUPPORT=y
CONFIG_SCSC_WLAN_SAR_SUPPORTED=y
CONFIG_SCSC_WLAN_DYNAMIC_ITO=y
CONFIG_SCSC_WLAN_ENHANCED_BIGDATA=y
CONFIG_SCSC_WLAN_MAX_INTERFACES=12
CONFIG_SCSC_AP_INTERFACE_NAME="swlan0"
CONFIG_SCSC_AP_INTERFACE_NAME_ALT="wlan1"

# ── Audio ───────────────────────────────────────────────────────────────────
CONFIG_SND_SOC_SAMSUNG_ABOX=m
CONFIG_SND_SOC_RT5665=m
CONFIG_SND_SOC_RT5691=m
CONFIG_SND_SOC_TFA9878=m
CONFIG_SND_SOC_AW882XX=m
CONFIG_SND_SOC_TAS2562=m
CONFIG_SND_USB_AUDIO=m
CONFIG_SND_SOC_SAMSUNG_VTS=m
CONFIG_SND_SOC_SAMSUNG_SLIF=m

# ── MFC (Video Codec) ──────────────────────────────────────────────────────
CONFIG_MEDIA_SAMSUNG_MFC=m
CONFIG_VIDEO_EXYNOS_MFC_BUFFER_ALIGN_128B=y
CONFIG_MFC_USES_LLC=y
CONFIG_SENSOR_RETENTION_USE=y

# ── GPU (Mali G78) ─────────────────────────────────────────────────────────
CONFIG_MALI_MIDGARD=m
CONFIG_MALI_EXYNOS_DVFS=y
CONFIG_MALI_EXYNOS_RTPM=y
CONFIG_MALI_EXYNOS_PM=y
CONFIG_MALI_EXYNOS_IFPO=y
CONFIG_MALI_CL_BOOST=y

# ── Input ───────────────────────────────────────────────────────────────────
CONFIG_SEC_INPUT=m
CONFIG_SEC_INPUT_BOOSTER=m
CONFIG_SEC_INPUT_BOOSTER_HANDLER=y
CONFIG_SEC_TOUCHSCREEN_DEVICE=y
CONFIG_SLSI=y
CONFIG_SEC_INPUT_TCLMV2_HANDLER=y

# ── Sensors ─────────────────────────────────────────────────────────────────
CONFIG_SHUB=m
CONFIG_SHUB_PM_WAKEUP_LINUX_VER_5_4=y
CONFIG_SHUB_AOIS=y
CONFIG_SHUB_PANEL_NOTIFY=y
CONFIG_SHUB_MODULE=y
CONFIG_SHUB_LSI=y
CONFIG_SENSORS_SX9380=m
CONFIG_SENSORS_A96T396=m
CONFIG_SENSORS_ISG5320A=m
CONFIG_SENSORS_ISG6320=m

# ── Battery / Charger ──────────────────────────────────────────────────────
CONFIG_BATTERY_SAMSUNG=m
CONFIG_STEP_CHARGING=y
CONFIG_ENABLE_FULL_BY_SOC=y
CONFIG_SEC_PD=m
CONFIG_BATTERY_CISD=y
CONFIG_AFC_CHARGER_MODE=y
CONFIG_BATTERY_AGE_FORECAST=y
CONFIG_BATTERY_LOGGING=y
CONFIG_UPDATE_BATTERY_DATA=y
CONFIG_LIMIT_CHARGING_DURING_CALL=y
CONFIG_BATTERY_GKI=y
CONFIG_SUPPORT_HV_CTRL=y
CONFIG_BATTERY_SAMSUNG_REBOOT=y
CONFIG_DIRECT_CHARGING=m
CONFIG_CHARGER_S2MF301=m
CONFIG_CHARGER_HL7132=m
CONFIG_LSI_IFPMIC=y
CONFIG_FUELGAUGE_S2MF301=m
CONFIG_FUELGAUGE_S2MF301_USE_5MILLIOHM=y
CONFIG_UI_SOC_PROLONGING=y
CONFIG_HICCUP_CHARGER=y

# ── Fingerprint ─────────────────────────────────────────────────────────────
CONFIG_FINGERPRINT_EGSTEC=m
CONFIG_FINGERPRINT_SECURE=y

# ── Touchscreen ─────────────────────────────────────────────────────────────
CONFIG_TOUCHSCREEN_GOODIX_BRL=m
CONFIG_TOUCHSCREEN_FTS_FT3519=m

# ── USB ─────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_USB_DWC3_EXYNOS=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_OTG=y
CONFIG_TYPEC=y

# ── Storage ─────────────────────────────────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_DW_EXYNOS=y
CONFIG_SCSI_UFS_EXYNOS=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y

# ── NFC ─────────────────────────────────────────────────────────────────────
CONFIG_NFC=y
CONFIG_NFC_NXP=m

# ── MUIC (Charging Port) ───────────────────────────────────────────────────
CONFIG_USE_MUIC=y
CONFIG_MUIC_NOTIFIER=m
CONFIG_MUIC_S2MF301=m
CONFIG_HV_MUIC_S2MF301_AFC=y

# ── USB Type-C ──────────────────────────────────────────────────────────────
CONFIG_USB_TYPEC_MANAGER_NOTIFIER=m
CONFIG_IF_CB_MANAGER=m

# ── Hall IC ─────────────────────────────────────────────────────────────────
CONFIG_INPUT_HALL_IC=m
CONFIG_HALL_NOTIFIER=m

# ── MST (Samsung Pay) ──────────────────────────────────────────────────────
CONFIG_MST_LDO=m
CONFIG_MST_ARCH_EXYNOS=y
CONFIG_MST_SUPPORT_GPIO=y
CONFIG_MST_IF_PMIC=y

# ── Security hardening ─────────────────────────────────────────────────────
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_MTE=y
CONFIG_ARM64_AMU_EXTN=y
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y
CONFIG_RESET_ATTACK_MITIGATION=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=32768
CONFIG_DEFAULT_MMAP_MIN_ADDR_64BIT=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_CFI_CLANG=y
CONFIG_SHADOW_CALL_STACK=y
CONFIG_SECURITY_PERF_EVENTS_RESTRICT=y
CONFIG_PAGE_TABLE_ISOLATION=y

# ── Yama LSM ────────────────────────────────────────────────────────────────
CONFIG_SECURITY_YAMA=y

# ── Performance ─────────────────────────────────────────────────────────────
CONFIG_SCHED_CLASS_EXT=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CAKE=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_FQ=y
CONFIG_MGLRU=y
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_LRU_WRITEBACK=y
CONFIG_KZEROD=y
CONFIG_HUGEPAGE_POOL=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_MEMCG_SWAP_ENABLED=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_MEMCG=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_CGROUP_DEBUG=y

# ── Memory ──────────────────────────────────────────────────────────────────
CONFIG_LOW_MEM_ADJUST=n
CONFIG_ZSMALLOC=y
CONFIG_ZSMALLOC_STAT=y
CONFIG_CRYPTO_ZSTD=y

# ── CPU frequency ───────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_SCHEDUTIL=y

# ── Energy Aware Scheduling ─────────────────────────────────────────────────
CONFIG_ENERGY_MODEL=y
CONFIG_SCHED_MC=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y

# ── Thermal ─────────────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_THERMAL_EMULATION=y
CONFIG_EXYNOS_THERMAL=y

# ── WQ (Work Queue) ─────────────────────────────────────────────────────────
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y

# ── KernelSU ────────────────────────────────────────────────────────────────
CONFIG_KSU=y

# ── BOEFFLA WakeLock Blocker ───────────────────────────────────────────────
CONFIG_BOEFFLA_WL_BLOCKER=y

# ── Build info ──────────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-ExynosNext"
CONFIG_LOCALVERSION_AUTO=n
