# ExynosNext vendor configuration fragment
# Applied on top of gki_defconfig

# ── SoC: Exynos 1280 ──────────────────────────────────────────────
CONFIG_ARCH_EXYNOS=y
CONFIG_ARCH_EXYNOS_AUTO=n
CONFIG_SOC_S5E8825=y

# ── Clock controller ───────────────────────────────────────────────
CONFIG_COMMON_CLK_S5E8825=m

# ── Display ────────────────────────────────────────────────────────
CONFIG_DRM_SAMSUNG_DPU=m
CONFIG_DRM_SAMSUNG_DECON=y
CONFIG_DRM_SAMSUNG_DSI=m
CONFIG_DRM_SAMSUNG_PANEL=y
CONFIG_DRM_SAMSUNG_DPP=y

# ── Power domain ───────────────────────────────────────────────────
CONFIG_EXYNOS_PD=m

# ── Modem ──────────────────────────────────────────────────────────
CONFIG_SAMSUNG_CPIF=m

# ── WiFi ───────────────────────────────────────────────────────────
CONFIG_SCSC_WLAN=m

# ── Audio ──────────────────────────────────────────────────────────
CONFIG_SND_SOC_SAMSUNG_ABOX=m
CONFIG_SND_SOC_RT5665=m
CONFIG_SND_SOC_RT5691=m
CONFIG_SND_SOC_TFA9878=m
CONFIG_SND_SOC_AW882XX=m

# ── MFC (Video Codec) ─────────────────────────────────────────────
CONFIG_MEDIA_SAMSUNG_MFC=m

# ── GPU ────────────────────────────────────────────────────────────
CONFIG_MALI_MIDGARD=m

# ── Input ──────────────────────────────────────────────────────────
CONFIG_SEC_INPUT=m
CONFIG_SEC_INPUT_BOOSTER=m

# ── Sensors ────────────────────────────────────────────────────────
CONFIG_SHUB=m

# ── Battery ────────────────────────────────────────────────────────
CONFIG_BATTERY_SAMSUNG=m
CONFIG_CHARGER_S2MF301=m
CONFIG_CHARGER_HL7132=m

# ── Fingerprint ────────────────────────────────────────────────────
CONFIG_FINGERPRINT_EGSTEC=m

# ── KernelSU ───────────────────────────────────────────────────────
CONFIG_KSU=y

# ── Security hardening ─────────────────────────────────────────────
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_MTE=y
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y
CONFIG_RESET_ATTACK_MITIGATION=y
CONFIG_RANDOMIZE_BASE=y

# ── Performance ────────────────────────────────────────────────────
CONFIG_SCHED_CLASS_EXT=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_MGLRU=y
CONFIG_ZRAM=y
CONFIG_KZEROD=y

# ── CFI (Control Flow Integrity) ───────────────────────────────────
CONFIG_CFI_CLANG=y
CONFIG_SHADOW_CALL_STACK=y
