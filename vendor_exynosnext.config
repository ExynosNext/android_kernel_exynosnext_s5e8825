# ============================================================================
# ExynosNext Kernel Configuration Fragment
# Applied on top of gki_defconfig via merge_config.sh
# Target: Samsung Exynos 1280 (s5e8825) — Linux 6.18 LTS
# Only standard GKI/upstream options that exist in vanilla 6.18 kernel
# Samsung-specific options will be added when vendor modules are ready
# ============================================================================

# ── SoC platform ────────────────────────────────────────────────────────────
CONFIG_ARCH_EXYNOS=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_IOMMU_SUPPORT=y

# ── Power management ────────────────────────────────────────────────────────
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_PM_RUNTIME=y
CONFIG_PM_AUTOSLEEP=y
CONFIG_PM_WAKELOCKS=y
CONFIG_CPU_IDLE=y

# ── Display / DRM ───────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_PANEL_BRIDGE=y
CONFIG_DRM_CDNS_MHDP8546=m

# ── USB ─────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_OTG=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_UCSI=y

# ── Storage ─────────────────────────────────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_DW=y
CONFIG_MMC_DW_EXYNOS=y
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFS_EXYNOS=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y

# ── Security hardening ─────────────────────────────────────────────────────
CONFIG_ARM64_PTR_AUTH=y
CONFIG_ARM64_PTR_AUTH_KERNEL=y
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_MTE=y
CONFIG_ARM64_AMU_EXTN=y
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y
CONFIG_RESET_ATTACK_MITIGATION=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_DEFAULT_MMAP_MIN_ADDR=32768
CONFIG_HARDENED_USERCOPY=y
CONFIG_CFI_CLANG=y
CONFIG_SHADOW_CALL_STACK=y
CONFIG_PAGE_TABLE_ISOLATION=y

# ── Yama LSM ────────────────────────────────────────────────────────────────
CONFIG_SECURITY_YAMA=y

# ── Performance ─────────────────────────────────────────────────────────────
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_CAKE=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NET_SCH_FQ=y
CONFIG_MGLRU=y
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_LRU_WRITEBACK=y
CONFIG_ZSMALLOC=y
CONFIG_ZSMALLOC_STAT=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_MEMCG_SWAP_ENABLED=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_MEMCG=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_CGROUP_DEBUG=y

# ── CPU frequency ───────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_SCHEDUTIL=y

# ── Energy Aware Scheduling ─────────────────────────────────────────────────
CONFIG_ENERGY_MODEL=y
CONFIG_SCHED_MC=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y

# ── Thermal ─────────────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_THERMAL_EMULATION=y

# ── Work Queue ──────────────────────────────────────────────────────────────
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y

# ── Build info ──────────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-ExynosNext"
CONFIG_LOCALVERSION_AUTO=n
